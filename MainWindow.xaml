<Window x:Class="Chat_Bot_Part2_POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chat_Bot_Part2_POE"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <!-- Parent grid -->
    <Grid>

        <!-- Logo grid -->
        <Grid>
            <TextBlock x:Name="logoBlock"
                       FontFamily="Consolas"
                       TextWrapping="NoWrap"
                       Margin="10"/>
        </Grid>

        <!-- Username grid -->
        <Grid x:Name="name_grid" 
              Visibility="Visible">

            <TextBox Height="50" 
                     Width="350" 
                     x:Name="user_name"/>

            <Button Height="50" 
                    Width="350" 
                    Margin="0,150,0,0"
                    Content="submit username"
                    Click="Submit_Username"/>
        </Grid>
        <!--End of username grid -->

        <!-- Chats grid -->
        <Grid x:Name="chat_grid" 
              Visibility="Hidden">

            <!--ListView to display the chats-->
            <ListView Height="350"
                      Width="400" 
                      Margin="0,0,0,70" 
                      x:Name="chats"/>

            <TextBox Height="50" 
                     Width="200" 
                     Margin="0,350,200,0" 
                     x:Name="question"/>

            <Button Height="50" 
                    Width="200" 
                    Margin="220,350,0,0"
                    Content="send"
                    Click="SendMessage"/>
        </Grid>

    </Grid>
</Window>