<Window x:Class="Chat_Bot_Part2_POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chat_Bot_Part2_POE"
        mc:Ignorable="d"
        Title="CyberSecurity Chatbot" 
        Height="650" 
        Width="1100"
        MinHeight="650"
        MinWidth="1100"
        ResizeMode="CanResize">

    <!-- Parent grid -->
    <Grid>

        <!-- Logo grid -->
        <Grid>
            <Image x:Name="logoImage"
       Width="400"
       Height="120"
       Stretch="Uniform"
       HorizontalAlignment="Center"
       VerticalAlignment="Top"
       Margin="0,20,40,0"
       Source="logo.png"/>

        </Grid>
        <!--End of logo grid -->

        <!-- Username grid -->
        <Grid x:Name="name_grid" 
              Visibility="Visible">

            <TextBox Height="50" 
                     Width="350" 
                     x:Name="user_name"/>

            <Button Height="50" 
                    Width="350" 
                    Margin="0,150,0,0"
                    Content="submit username"
                    Click="Submit_Username"/>
        </Grid>
        <!--End of username grid -->

        
        
        <!-- Main feature area shown after the username is submitted -->
        <TabControl x:Name="chat_grid"
            Visibility="Hidden"
            Margin="20,150,20,20">

            <!-- Tab  tp keep the chatbot and task assistant together -->
            <TabItem Header="Chatbot and Tasks">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Chat section -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="60" />
                        </Grid.RowDefinitions>

                        <!-- Displaying of the chatbot conversation -->
                        <ListView x:Name="chats"
                          Grid.Row="0"
                          Margin="0,0,0,10" />

                        <!-- User input area -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="question"
                             Grid.Column="0"
                             Height="40"
                             Margin="0,0,10,0"
                             KeyDown="Question_KeyDown" />

                            <Button Grid.Column="1"
                            Height="40"
                            Content="Send"
                            Click="SendMessage" />
                        </Grid>
                    </Grid>

                    <!-- Task assistant section -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                           Text="Task Assistant"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10" />

                        <TextBlock Grid.Row="1"
                           Text="Task Title" />

                        <TextBox x:Name="taskTitle"
                         Grid.Row="2"
                         Height="35"
                         Margin="0,5,0,10" />

                        <TextBlock Grid.Row="3"
                           Text="Task Description" />

                        <TextBox x:Name="taskDescription"
                         Grid.Row="4"
                         Height="60"
                         Margin="0,5,0,10"
                         TextWrapping="Wrap"
                         AcceptsReturn="True" />

                        <StackPanel Grid.Row="5"
                            Margin="0,0,0,10">
                            <TextBlock Text="Reminder Date" />

                            <DatePicker x:Name="taskReminderDate"
                                Height="35"
                                Margin="0,5,0,10" />

                            <Button Content="Add Task"
                            Height="35"
                            Click="AddTask_Click" />
                        </StackPanel>

                        <ListView x:Name="taskList"
                          Grid.Row="6"
                          Margin="0,0,0,10"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Title"
                                            DisplayMemberBinding="{Binding Title}"
                                            Width="110" />
                                    <GridViewColumn Header="Description"
                                            DisplayMemberBinding="{Binding Description}"
                                            Width="160" />
                                    <GridViewColumn Header="Reminder"
                                            DisplayMemberBinding="{Binding ReminderText}"
                                            Width="100" />
                                    <GridViewColumn Header="Status"
                                            DisplayMemberBinding="{Binding Status}"
                                            Width="80" />
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <StackPanel Grid.Row="7"
                            Orientation="Horizontal">
                            <Button Content="Complete"
                            Width="100"
                            Height="35"
                            Margin="0,0,10,0"
                            Click="CompleteTask_Click" />

                            <Button Content="Delete"
                            Width="100"
                            Height="35"
                            Click="DeleteTask_Click" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Second tab for the cybersecurity quiz mini-game -->
            <TabItem Header="Cyber Quiz">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Quiz title -->
                    <TextBlock Grid.Row="0"
                       Text="Cybersecurity Quiz"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,10" />

                    <!-- Score and question number display -->
                    <TextBlock x:Name="quizProgressText"
                       Grid.Row="1"
                       Text="Click Start Quiz to begin."
                       FontSize="14"
                       Margin="0,0,0,15" />

                    <!-- Question and answer area -->
                    <StackPanel Grid.Row="2">
                        <TextBlock x:Name="quizQuestionText"
                           Text="Question will appear here."
                           FontSize="18"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15" />

                        <!-- Answer choices -->
                        <RadioButton x:Name="answerOptionA"
                             GroupName="QuizAnswers"
                             FontSize="15"
                             Margin="0,5,0,5" />

                        <RadioButton x:Name="answerOptionB"
                             GroupName="QuizAnswers"
                             FontSize="15"
                             Margin="0,5,0,5" />

                        <RadioButton x:Name="answerOptionC"
                             GroupName="QuizAnswers"
                             FontSize="15"
                             Margin="0,5,0,5" />

                        <RadioButton x:Name="answerOptionD"
                             GroupName="QuizAnswers"
                             FontSize="15"
                             Margin="0,5,0,5" />
                    </StackPanel>

                    <!-- Logic to provide immediate feedback after each answer -->
                    <TextBlock x:Name="quizFeedbackText"
                       Grid.Row="3"
                       Text=""
                       FontSize="15"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="0,15,0,15" />

                    <!-- Quiz controls -->
                    <StackPanel Grid.Row="4"
                        Orientation="Horizontal">
                        <Button x:Name="startQuizButton"
                        Content="Start Quiz"
                        Width="110"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="StartQuiz_Click" />

                        <Button x:Name="submitAnswerButton"
                        Content="Submit Answer"
                        Width="130"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="SubmitAnswer_Click"
                        IsEnabled="False" />

                        <Button x:Name="nextQuestionButton"
                        Content="Next Question"
                        Width="130"
                        Height="35"
                        Click="NextQuestion_Click"
                        IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl> <!--End of tab control for chats grid-->
        
        
        
        
        
    </Grid>
</Window>