<Window x:Class="Chat_Bot_Part2_POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chat_Bot_Part2_POE"
        mc:Ignorable="d"
        Title="CyberSecurity Chatbot" Height="600" Width="1000">

    <!-- Parent grid -->
    <Grid>

        <!-- Logo grid -->
        <Grid>
            <Image x:Name="logoImage"
       Width="400"
       Height="120"
       Stretch="Uniform"
       HorizontalAlignment="Center"
       VerticalAlignment="Top"
       Margin="0,20,40,0"
       Source="logo.png"/>

        </Grid>
        <!--End of logo grid -->

        <!-- Username grid -->
        <Grid x:Name="name_grid" 
              Visibility="Visible">

            <TextBox Height="50" 
                     Width="350" 
                     x:Name="user_name"/>

            <Button Height="50" 
                    Width="350" 
                    Margin="0,150,0,0"
                    Content="submit username"
                    Click="Submit_Username"/>
        </Grid>
        <!--End of username grid -->

        <!-- Chat and task assistant grid -->
        <Grid x:Name="chat_grid" Visibility="Hidden" Margin="20,150,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Chat section -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="60" />
                </Grid.RowDefinitions>

                <!--To display the chats in list view-->
                <ListView x:Name="chats"
                  Grid.Row="0"
                  Margin="0,0,0,10" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="question"
                     Grid.Column="0"
                     Height="40"
                     Margin="0,0,10,0"
                     KeyDown="Question_KeyDown" />

                    <Button Grid.Column="1"
                    Height="40"
                    Content="Send"
                    Click="SendMessage" />
                </Grid>
            </Grid>

            <!-- Task assistant section -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
               Text="Task Assistant"
               FontSize="20"
               FontWeight="Bold"
               Margin="0,0,0,10" />

                <TextBlock Grid.Row="1"
               Text="Task Title" />

                <TextBox x:Name="taskTitle"
             Grid.Row="2"
             Height="35"
             Margin="0,5,0,10" />

                <TextBlock Grid.Row="3"
               Text="Task Description" />

                <TextBox x:Name="taskDescription"
             Grid.Row="4"
             Height="60"
             Margin="0,5,0,10"
             TextWrapping="Wrap"
             AcceptsReturn="True" />

                <StackPanel Grid.Row="5"
                Margin="0,0,0,10">
                    <TextBlock Text="Reminder Date" />

                    <DatePicker x:Name="taskReminderDate"
                    Height="35"
                    Margin="0,5,0,10" />

                    <Button Content="Add Task"
                Height="35"
                Click="AddTask_Click" />
                </StackPanel>

                <ListView x:Name="taskList"
              Grid.Row="6"
              Margin="0,0,0,10"
              ScrollViewer.VerticalScrollBarVisibility="Auto"
              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Title"
                                DisplayMemberBinding="{Binding Title}"
                                Width="110" />
                            <GridViewColumn Header="Description"
                                DisplayMemberBinding="{Binding Description}"
                                Width="160" />
                            <GridViewColumn Header="Reminder"
                                DisplayMemberBinding="{Binding ReminderText}"
                                Width="100" />
                            <GridViewColumn Header="Status"
                                DisplayMemberBinding="{Binding Status}"
                                Width="80" />
                        </GridView>
                    </ListView.View>
                </ListView>

                <StackPanel Grid.Row="7"
                Orientation="Horizontal">
                    <Button Content="Complete"
                Width="100"
                Height="35"
                Margin="0,0,10,0"
                Click="CompleteTask_Click" />

                    <Button Content="Delete"
                Width="100"
                Height="35"
                Click="DeleteTask_Click" />
                </StackPanel>
            </Grid>



        </Grid> <!--end of chats grid-->

    </Grid>
</Window>