<Window x:Class="Chat_Bot_Part2_POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chat_Bot_Part2_POE"
        mc:Ignorable="d"
        Title="CyberSecurity Chatbot" 
        Height="650" 
        Width="1100"
        MinHeight="650"
        MinWidth="1100"
        ResizeMode="CanResize"
        Background="Black"
        FontFamily="Segoe UI"
        Foreground="AntiqueWhite">
    
    
    

    <!-- Window resources for styling -->

    <Window.Resources>

        <!-- Main colours -->
        <SolidColorBrush x:Key="PrimaryBg" Color="#121212"/>
        <SolidColorBrush x:Key="SecondaryBg" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#7C4DFF"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#42A5F5"/>
        <SolidColorBrush x:Key="TextPrimary" Color="White"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#B0B0B0"/>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#7C4DFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Hover effect for the buttons -->
        <Style TargetType="Button" x:Key="HoverButton">
            <Setter Property="Background" Value="#7C4DFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#42A5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#333"/>

            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#7C4DFF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--Style for the ListView-->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
        </Style>

        <!--Style for the Grid-->
        <Style TargetType="Grid">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!--TO enhance textblock readability-->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>
    
    <!--End of window resources-->

    

    <!-- Parent grid -->
    <Grid Background="{StaticResource PrimaryBg}">

        <!-- Logo grid -->
        <Grid>
            <Image x:Name="logoImage"
           Width="400"
           Height="120"
           Stretch="Uniform"
           HorizontalAlignment="Center"
           VerticalAlignment="Top"
           Margin="0,20,40,0"
           Source="logo.png"/>

        </Grid>
        <!--End of logo grid -->

        <!-- Username grid -->
        <Grid x:Name="name_grid" 
              Visibility="Visible">

            <TextBox Height="50" 
                     Width="350" 
                     x:Name="user_name"/>

            <Button Height="50" 
                    Width="350" 
                    Margin="0,150,0,0"
                    Content="submit username"
                    Click="Submit_Username"/>
            
        </Grid>
        <!--End of username grid -->

        
        
        <!-- Main feature area shown after the username is submitted -->
        <TabControl x:Name="chat_grid"
            Visibility="Hidden"
            Margin="20,150,20,20">

            <!-- Tab  tp keep the chatbot and task assistant together -->
            <TabItem Header="Chatbot and Tasks">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Chat section -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="60" />
                        </Grid.RowDefinitions>

                        <!-- Displaying of the chatbot conversation  -->
                        <ListView x:Name="chats"
                          Grid.Row="0"
                          Margin="0,0,0,10"
                          Background="Transparent"
                          BorderThickness="0">

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ItemTemplate>
                                <DataTemplate>

                                    <!-- Outer container for each message -->
                                    <Grid Margin="8">

                                        <!-- Two-column layout: Left = bot...Right = user -->
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        
                                        
                                        <!-- BOT MESSAGE -->
                                        <!-- Bot container -->
                                        <StackPanel Orientation="Horizontal"
                                         Grid.Column="0"
                                         Margin="0,0,50,0">

                                            <!-- Hide the entire bot container if this is a user message -->
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <!--  Bot avatar -->
                                            <TextBlock Text="🛡"
                                             FontSize="20"
                                             Margin="0,5,8,0"
                                             VerticalAlignment="Top"/>

                                            <!-- Bot message bubble -->
                                            <Border Padding="12"
                                            MaxWidth="360"
                                            Background="#2A2A2A"
                                            CornerRadius="12"
                                            HorizontalAlignment="Left">

                                                

                                                <!-- The chatbot's message -->
                                                <TextBlock Text="{Binding Message}"
                                                   TextWrapping="Wrap"
                                                   Foreground="White"
                                                   FontSize="14"/>
                                            </Border>

                                        </StackPanel>

                                        <!--  USER MESSAGE -->
                                        <Border Grid.Column="1"
                                        Padding="12"
                                        Margin="50,0,0,0"
                                        MaxWidth="360"
                                        Background="#7C4DFF"
                                        CornerRadius="12"
                                        HorizontalAlignment="Right">

                                            <!-- Hide if NOT user -->
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <!-- Message text -->
                                            <TextBlock Text="{Binding Message}"
                           TextWrapping="Wrap"
                           Foreground="White"
                           FontSize="14"/>
                                        </Border>

                                    </Grid>

                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>


                        <!-- User input area -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <!-- User message input -->
                            <TextBox x:Name="question"
                             Grid.Column="0"
                             Height="42"
                             Margin="0,0,10,0"
                             Padding="12,8"
                             FontSize="14"
                             Background="#252525"
                             Foreground="White"
                             BorderBrush="#444"
                             BorderThickness="1"
                             CaretBrush="White"
                             KeyDown="Question_KeyDown"
                             ToolTip="Ask me about cybersecurity..."/>

                            <!-- Send button -->
                            <Button Grid.Column="1"
                             Height="42"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Content="➤ Send"
                             Click="SendMessage"/>
                        </Grid>
                    </Grid>

                    <!-- Task assistant section -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="2" MinHeight="180" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Task Assistant title -->
                        <TextBlock Grid.Row="0"
                         Text="🛡 Task Assistant"
                         FontSize="24"
                         FontWeight="Bold"
                          Foreground="White"
                           Margin="0,0,0,20"/>

                        <TextBlock Grid.Row="1"
                           Text="🛡 Task Title" />

                        <TextBox x:Name="taskTitle"
                         Grid.Row="2"
                         Height="35"
                         Margin="0,5,0,10" />

                        <TextBlock Grid.Row="3"
                           Text="Task Description" />

                        <TextBox x:Name="taskDescription"
                         Grid.Row="4"
                         Height="60"
                         Margin="0,5,0,10"
                         TextWrapping="Wrap"
                         AcceptsReturn="True" />

                        <StackPanel Grid.Row="5"
                            Margin="0,0,0,10">
                            <TextBlock Text="Reminder Date" />

                            <DatePicker x:Name="taskReminderDate"
                                Height="35"
                                Margin="0,5,0,10" />

                            <Button Content="Add Task"
                            Height="35"
                            Click="AddTask_Click" />
                        </StackPanel>

                        <ListView x:Name="taskList"
                          Grid.Row="6"
                          MinHeight="180" 
                          Margin="0,0,0,10"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListView.View>
                                
                                
                                
                                <GridView>
                                    <GridViewColumn Header="Title"
                                            DisplayMemberBinding="{Binding Title}"
                                            Width="110" />
                                    <GridViewColumn Header="Description"
                                            DisplayMemberBinding="{Binding Description}"
                                            Width="160" />
                                    <GridViewColumn Header="Reminder"
                                            DisplayMemberBinding="{Binding ReminderText}"
                                            Width="100" />
                                    <GridViewColumn Header="Status"
                                            DisplayMemberBinding="{Binding Status}"
                                            Width="80" />
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <StackPanel Grid.Row="7"
                            Orientation="Horizontal">
                            <Button Content="Complete"
                            Width="100"
                            Height="35"
                            Margin="0,0,10,0"
                            Click="CompleteTask_Click" />

                            <Button Content="Delete"
                            Width="100"
                            Height="35"
                            Click="DeleteTask_Click" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Second tab for the cybersecurity quiz mini-game -->
            <TabItem Header="Cyber Quiz">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Quiz title -->
                    <TextBlock Grid.Row="0"
                       Text="Cybersecurity Quiz"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,10" />

                    <!-- Score and question number display -->
                    <TextBlock x:Name="quizProgressText"
                       Grid.Row="1"
                       Text="Click Start Quiz to begin."
                       FontSize="14"
                       Margin="0,0,0,15" />

                    <!-- Question and answer area -->
                    <StackPanel Grid.Row="2">
                        <TextBlock x:Name="quizQuestionText"
                           Foreground="AntiqueWhite"
                           Text="Question will appear here."
                           FontSize="18"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15" />

                        <!-- Answer choices -->
                        <RadioButton x:Name="answerOptionA"
                             Foreground="AntiqueWhite"
                             GroupName="QuizAnswers"
                             FontSize="15"
                             Margin="0,5,0,5" />

                        <RadioButton x:Name="answerOptionB"
                             Foreground="AntiqueWhite"
                             GroupName="QuizAnswers"
                             FontSize="15"
                             Margin="0,5,0,5" />

                        <RadioButton x:Name="answerOptionC"
                             Foreground="AntiqueWhite"
                             GroupName="QuizAnswers"
                             FontSize="15"
                             Margin="0,5,0,5" />

                        <RadioButton x:Name="answerOptionD"
                             Foreground="AntiqueWhite"
                             GroupName="QuizAnswers"
                             FontSize="15"
                             Margin="0,5,0,5" />
                    </StackPanel>

                    <!-- Logic to provide immediate feedback after each answer -->
                    <TextBlock x:Name="quizFeedbackText"
                       Grid.Row="3"
                       Text=""
                       FontSize="15"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="0,15,0,15" />

                    <!-- Quiz controls -->
                    <StackPanel Grid.Row="4"
                        Orientation="Horizontal">
                        <Button x:Name="startQuizButton"
                        Content="Start Quiz"
                        Width="110"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="StartQuiz_Click" />

                        <Button x:Name="submitAnswerButton"
                        Content="Submit Answer"
                        Width="130"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="SubmitAnswer_Click"
                        IsEnabled="False" />

                        <Button x:Name="nextQuestionButton"
                        Content="Next Question"
                        Width="130"
                        Height="35"
                        Click="NextQuestion_Click"
                        IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl> <!--End of tab control for chats grid-->
        
        
        
      

    </Grid>
</Window>